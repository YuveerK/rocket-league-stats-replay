      },
      "presentation": {
        "label": "Frontend",
        "group": "dev",
        "panel": "dedicated",
        "reveal": "always"
      },
      "problemMatcher": []
    },
    {
      "label": "Start Parser Watch",
      "type": "shell",
      "command": "npm run watch",
      "options": {
        "cwd": "${workspaceFolder}/parser"
      },
      "presentation": {
        "label": "Parser",
        "group": "dev",
        "panel": "dedicated",
        "reveal": "always"
      },
      "problemMatcher": []
    },
    {
